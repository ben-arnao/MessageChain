# Drop-in override for prototype-phase deployments (early bootstrap,
# single-validator test net, founder-launch entity baked into genesis).
#
# Install:
#   sudo install -d /etc/systemd/system/messagechain-validator.service.d
#   sudo cp deploy/systemd/messagechain-validator-prototype.conf.example \
#       /etc/systemd/system/messagechain-validator.service.d/profile.conf
#   sudo systemctl daemon-reload
#   sudo systemctl restart messagechain-validator
#
# What this flips (see messagechain/config.py _PROTOTYPE_OVERRIDES for
# the source of truth):
#   - MERKLE_TREE_HEIGHT = 16     (~5 min keygen vs hours; ~450 d hot-key vs ~2 y)
#   - BLOCK_TIME_TARGET  = 30     (fast iteration; production target is 600 s)
#   - REQUIRE_CHECKPOINTS = false (chain has < 1000 blocks; auto-waived anyway)
#   - RPC_AUTH_ENABLED   = false  (single-operator validator; no remote callers)
#
# Remove this file (and `systemctl daemon-reload`) before promoting the
# validator to mainnet operation.  The prod-default unit has none of
# these dev-time degradations — that is the whole point of keeping the
# prototype switch in a separate, opt-in file.

[Service]
Environment=MESSAGECHAIN_PROFILE=prototype
